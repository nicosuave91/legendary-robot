{
  "name": "snowball/crm-api",
  "type": "project",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "twilio/sdk": "^8.11"
  },
  "require-dev": {
    "pestphp/pest": "^3.8",
    "nunomaduro/larastan": "^3.7"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "contracts:publish": "php scripts/publish-openapi.php",
    "test": "phpunit",
    "test:contracts": "phpunit tests/Contract"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "Database\\Seeders\\": "database/seeders/"
    }
  }
}
